{
  "name": "sat-tracker",
  "version": "1.0.0",
  "description": "All-in-one satellite tracker for the web and Electron.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/copy-cesium.mjs public/cesium && electron-vite dev",
    "dev:web": "node scripts/copy-cesium.mjs public/cesium && vite --config vite.web.config.ts",
    "build": "npm run build:electron && npm run build:web",
    "build:web": "vite build --config vite.web.config.ts && node scripts/copy-cesium.mjs dist-web/cesium",
    "build:electron": "electron-vite build && node scripts/copy-cesium.mjs out/renderer/cesium",
    "dist": "npm run build:electron && electron-builder --publish never",
    "dist:win": "npm run build:electron && electron-builder --win nsis --win portable --publish never",
    "dist:installer": "npm run build:electron && electron-builder --win nsis --publish never",
    "dist:portable": "npm run build:electron && electron-builder --win portable --publish never",
    "dist:mac": "npm run build:electron && electron-builder --mac dmg --mac zip --publish never",
    "dist:linux": "npm run build:electron && electron-builder --linux AppImage --linux deb --publish never",
    "preview": "vite preview --config vite.web.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "keywords": [],
  "author": "Zion <zion@ziona.dev>",
  "license": "ISC",
  "type": "module",
  "desktopName": "sat-tracker",
  "build": {
    "appId": "com.sattracker.app",
    "productName": "Sat Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Science",
      "maintainer": "Zion <zion@ziona.dev>",
      "syncDesktopName": true,
      "icon": "build/icons"
    }
  },
  "dependencies": {
    "cesium": "^1.141.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.3",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "satellite.js": "^7.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.15.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  }
}
